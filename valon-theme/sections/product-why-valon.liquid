<section class="product-section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Pourquoi VALON</span>
      <h2 class="heading-serif heading-lg">Ce qui nous distingue</h2>
    </div>

    <div class="benefits-grid" style="grid-template-columns:1fr;">
      <div class="turkish-origin" style="margin-bottom:0;">
        <div class="turkish-origin__flag">🇹🇷</div>
        <div>
          <h3 class="heading-serif">Expertise Turque, Qualité Internationale</h3>
          <p>La Turquie est le berceau de certaines des meilleures formules capillaires au monde. VALON s'appuie sur cette tradition d'excellence pour créer des produits qui rivalisent avec les plus grandes marques de luxe.</p>
        </div>
      </div>
    </div>

    <div class="benefits-grid" style="margin-top:2rem;">
      <div class="benefit-card">
        <div class="benefit-card__icon">🏆</div>
        <h3>Formules Premium</h3>
        <p>Développées par des laboratoires turcs spécialisés en cosmétique naturelle.</p>
      </div>
      <div class="benefit-card">
        <div class="benefit-card__icon">📦</div>
        <h3>Packaging Luxe</h3>
        <p>Boîte cadeau blanche et dorée avec carte de remerciement personnalisée.</p>
      </div>
      <div class="benefit-card">
        <div class="benefit-card__icon">🤝</div>
        <h3>Service Client</h3>
        <p>Assistance WhatsApp dédiée pour chaque cliente, avant et après l'achat.</p>
      </div>
    </div>
  </div>
</section>

