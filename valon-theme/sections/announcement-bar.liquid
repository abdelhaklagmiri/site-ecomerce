{%- if section.settings.show_bar -%}
<div class="announcement-bar">
  {{ section.settings.text }}
</div>
{%- endif -%}

{% schema %}
{
  "name": "Barre d'annonce",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_bar",
      "label": "Afficher la barre",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Texte",
      "default": "✦ VALON Hair Care — Pack Complet 649 MAD — Livraison gratuite dès 399 DH — Paiement à la livraison ✦"
    }
  ]
}
{% endschema %}
