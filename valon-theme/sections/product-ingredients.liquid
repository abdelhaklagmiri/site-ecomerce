<section class="product-section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Ingrédients</span>
      <h2 class="heading-serif heading-lg">Des ingrédients nobles, rien de plus</h2>
      <p>Chaque ingrédient est soigneusement sélectionné pour son efficacité prouvée sur la santé capillaire.</p>
    </div>

    <div class="ingredients-grid">
      <div class="ingredient-card">
        <div class="ingredient-card__icon">🫒</div>
        <h4>Huile d'Argan</h4>
        <p>Nourrit, répare et apporte une brillance exceptionnelle</p>
      </div>
      <div class="ingredient-card">
        <div class="ingredient-card__icon">🌰</div>
        <h4>Huile de Jojoba</h4>
        <p>Hydrate sans alourdir, régule le sébum du cuir chevelu</p>
      </div>
      <div class="ingredient-card">
        <div class="ingredient-card__icon">🌿</div>
        <h4>Extraits de Plantes</h4>
        <p>Nettoie en douceur et purifie le cuir chevelu naturellement</p>
      </div>
      <div class="ingredient-card">
        <div class="ingredient-card__icon">💧</div>
        <h4>Kératine Végétale</h4>
        <p>Reconstruit la fibre capillaire et réduit les pointes fourchues</p>
      </div>
      <div class="ingredient-card">
        <div class="ingredient-card__icon">🌸</div>
        <h4>Huile de Ricin</h4>
        <p>Stimule la croissance et densifie la chevelure</p>
      </div>
      <div class="ingredient-card">
        <div class="ingredient-card__icon">🍃</div>
        <h4>Aloe Vera</h4>
        <p>Apaise le cuir chevelu et hydrate en profondeur</p>
      </div>
      <div class="ingredient-card">
        <div class="ingredient-card__icon">🧪</div>
        <h4>Biotine</h4>
        <p>Vitamine essentielle pour la force et la repousse capillaire</p>
      </div>
      <div class="ingredient-card">
        <div class="ingredient-card__icon">✨</div>
        <h4>Vitamine E</h4>
        <p>Antioxydant puissant qui protège et répare les cheveux</p>
      </div>
    </div>

    <p class="text-center text-muted" style="margin-top:2rem;font-size:0.85rem;">Sans sulfates · Sans silicones · Sans parabènes · Sans colorants artificiels</p>
  </div>
</section>

{% schema %}
{
  "name": "Ingrédients",
  "settings": [],
  "presets": [{ "name": "Ingrédients" }]
}
{% endschema %}
