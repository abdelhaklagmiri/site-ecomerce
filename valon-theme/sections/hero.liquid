<section class="hero">
  <div class="hero__bg">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1920 }}"
        alt="{{ section.settings.image.alt | default: 'VALON Hair Care — Sérum et Shampooing' }}"
        loading="eager"
        width="1920"
        height="1080"
      >
    {%- else -%}
      <div style="width:100%;height:100%;background:linear-gradient(135deg,#0a0a0a,#1a1510);"></div>
    {%- endif -%}
  </div>
  <div class="hero__overlay"></div>

  <div class="container hero__content animate-in">
    <span class="section-label">{{ section.settings.label }}</span>
    <h1 class="heading-serif heading-xl">{{ section.settings.heading }}</h1>
    <p>{{ section.settings.subheading }}</p>

    <div class="btn-group">
      <a href="{{ section.settings.cta_url }}" class="btn btn--primary">{{ section.settings.cta_text }}</a>
      <a href="{{ section.settings.cta_secondary_url }}" class="btn btn--outline">{{ section.settings.cta_secondary_text }}</a>
    </div>

    <div class="hero__trust">
      <div class="hero__trust-item">
        <strong>🇹🇷</strong> Formulé en Turquie
      </div>
      <div class="hero__trust-item">
        <strong>✦</strong> Paiement à la livraison
      </div>
      <div class="hero__trust-item">
        <strong>✦</strong> Livraison partout au Maroc
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image hero",
      "info": "Utiliser l'image produits avec éclaboussure d'huile dorée et noix d'argan"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Routine Capillaire Premium"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Titre",
      "default": "Sublimez vos cheveux avec <em>l'or liquide</em> de VALON"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "Le Pack Complet VALON combine notre Sérum Capillaire nourrissant et notre Shampooing purifiant — une routine luxueuse formulée en Turquie pour des cheveux plus forts, plus brillants et plus sains."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Bouton principal",
      "default": "Commander le Pack — 649 MAD"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Lien bouton principal"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "Bouton secondaire",
      "default": "Découvrir nos produits"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Lien bouton secondaire"
    }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
