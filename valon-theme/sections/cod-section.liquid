<section class="section">
  <div class="container">
    <div class="cod-section">
      <span class="section-label">Paiement sécurisé</span>
      <h2 class="heading-serif heading-md">Payez uniquement à la réception</h2>
      <p>Aucun paiement en avance. Aucun risque. Vous inspectez votre colis, et vous payez le livreur en espèces. C'est aussi simple que ça.</p>

      <div class="cod-steps">
        <div class="cod-step">
          <div class="cod-step__num">1</div>
          <h4>Commandez</h4>
          <p>Sur le site ou via WhatsApp</p>
        </div>
        <div class="cod-step">
          <div class="cod-step__num">2</div>
          <h4>Recevez</h4>
          <p>Livraison à domicile en 2-5 jours</p>
        </div>
        <div class="cod-step">
          <div class="cod-step__num">3</div>
          <h4>Payez</h4>
          <p>En espèces au livreur</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Section COD",
  "settings": [],
  "presets": [{ "name": "Section COD" }]
}
{% endschema %}
