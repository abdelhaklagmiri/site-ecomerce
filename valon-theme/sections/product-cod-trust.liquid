<section class="product-section">
  <div class="container">
    <div class="cod-section">
      <span class="section-label">Paiement sécurisé</span>
      <h2 class="heading-serif heading-md">Payez uniquement à la réception</h2>
      <p>Commandez en toute confiance. Vous payez le livreur en espèces uniquement après avoir reçu et inspecté votre colis.</p>
      <div class="cod-steps">
        <div class="cod-step"><div class="cod-step__num">1</div><h4>Commandez</h4><p>Sur le site ou WhatsApp</p></div>
        <div class="cod-step"><div class="cod-step__num">2</div><h4>Recevez</h4><p>Livraison 2-5 jours</p></div>
        <div class="cod-step"><div class="cod-step__num">3</div><h4>Payez</h4><p>En espèces au livreur</p></div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Confiance COD Produit",
  "settings": [],
  "presets": [{ "name": "Confiance COD Produit" }]
}
{% endschema %}
