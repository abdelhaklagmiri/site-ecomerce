<section class="section section--cream" id="faq">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Questions fréquentes</span>
      <h2 class="heading-serif heading-lg">Tout ce que vous devez savoir</h2>
    </div>
    <div class="faq-list">
      <div class="faq-item">
        <button class="faq-item__question">Comment passer commande ?<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14" stroke-linecap="round"/></svg></button>
        <div class="faq-item__answer"><p>Commandez sur le site ou via WhatsApp au 07 16 27 16 04. Paiement à la livraison uniquement.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-item__question">Combien de temps pour voir des résultats ?<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14" stroke-linecap="round"/></svg></button>
        <div class="faq-item__answer"><p>Résultats visibles dès 2-3 semaines d'utilisation régulière. Résultats optimaux après 2-3 mois.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-item__question">Convient à mon type de cheveux ?<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14" stroke-linecap="round"/></svg></button>
        <div class="faq-item__answer"><p>Oui, tous types de cheveux : fins, épais, bouclés, lisses, colorés ou naturels.</p></div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ Produit",
  "settings": [],
  "presets": [{ "name": "FAQ Produit" }]
}
{% endschema %}
