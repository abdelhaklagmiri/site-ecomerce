<section class="section"><div class="container page-content text-center">
  <img src="{{ 'valon-logo.svg' | asset_url }}" alt="VALON Hair Care" width="160" style="margin:0 auto 2rem;">
  <h1 class="heading-serif heading-md">Boutique en préparation</h1>
  {% form 'storefront_password' %}
    <input type="password" name="password" placeholder="Mot de passe" style="width:100%;max-width:320px;padding:1rem;margin:1rem 0;border:1px solid var(--color-gray-light);">
    <button type="submit" class="btn btn--primary btn--full" style="max-width:320px;margin:0 auto;">Entrer</button>
  {% endform %}
</div></section>
{% schema %}{"name":"Mot de passe","settings":[],"presets":[{"name":"Mot de passe"}]}{% endschema %}
