// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Scalable partner types for barbers, salons, pharmacies, and cosmetic stores.
enum PartnerType {
  BARBER
  SALON
  PHARMACY
  COSMETIC_STORE
}

/// Foundation model — extend as feature modules are implemented.
model Partner {
  id        String      @id @default(cuid())
  type      PartnerType @default(BARBER)
  name      String
  email     String?
  phone     String?
  city      String?
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([type])
  @@index([isActive])
  @@map("partners")
}
