<footer class="valon-footer">
  <div class="valon-container">
    <div class="valon-footer__grid">
      <div class="valon-footer__brand">
        <a href="/" class="valon-logo">VAL<span>ON</span></a>
        <p>VALON réinvente les soins capillaires pour les femmes marocaines. Des formules premium, inspirées par la nature et conçues pour des résultats visibles.</p>
      </div>

      <div>
        <h4 class="valon-footer__heading">Boutique</h4>
        <ul class="valon-footer__links">
          <li><a href="/collections/all">Tous les produits</a></li>
          <li><a href="/collections/soins-capillaires">Soins capillaires</a></li>
          <li><a href="/collections/kits">Kits & Coffrets</a></li>
        </ul>
      </div>

      <div>
        <h4 class="valon-footer__heading">Aide</h4>
        <ul class="valon-footer__links">
          <li><a href="/pages/contact">Contact</a></li>
          <li><a href="/pages/livraison">Livraison</a></li>
          <li><a href="/pages/retours">Retours & Échanges</a></li>
          <li><a href="/pages/faq">FAQ</a></li>
        </ul>
      </div>

      <div>
        <h4 class="valon-footer__heading">Légal</h4>
        <ul class="valon-footer__links">
          <li><a href="/pages/notre-histoire">Notre Histoire</a></li>
          <li><a href="/pages/confidentialite">Confidentialité</a></li>
          <li><a href="/pages/conditions">Conditions Générales</a></li>
        </ul>
      </div>
    </div>

    <div class="valon-footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} VALON Hair Care. Tous droits réservés.</span>
      <div class="valon-footer__payments">
        <span class="valon-footer__payment-badge">COD</span>
        <span class="valon-footer__payment-badge">CMI</span>
        <span class="valon-footer__payment-badge">VISA</span>
        <span class="valon-footer__payment-badge">WhatsApp</span>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Pied de page VALON",
  "settings": []
}
{% endschema %}
