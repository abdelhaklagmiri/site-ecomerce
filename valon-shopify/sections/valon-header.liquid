<header class="valon-header">
  <div class="valon-header__inner">
    <a href="/" class="valon-logo">VAL<span>ON</span></a>

    <nav>
      <ul class="valon-nav">
        <li><a href="/">Accueil</a></li>
        <li><a href="/collections/all">Produits</a></li>
        <li><a href="/pages/notre-histoire">Notre Histoire</a></li>
        <li><a href="/pages/contact">Contact</a></li>
      </ul>
    </nav>

    <div class="valon-header__actions">
      <a href="/cart" class="valon-cart-btn" aria-label="Panier">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4H6z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        {% if cart.item_count > 0 %}
          <span class="valon-cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
      <button class="valon-menu-toggle" aria-label="Menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "En-tête VALON",
  "settings": []
}
{% endschema %}
