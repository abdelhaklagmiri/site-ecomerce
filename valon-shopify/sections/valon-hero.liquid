<section class="valon-hero">
  <div class="valon-hero__bg"></div>
  <div class="valon-hero__grid">
    <div class="valon-hero__content">
      <div class="valon-hero__badge">
        ★ N°1 en soins capillaires premium au Maroc
      </div>
      <h1 class="valon-hero__title">
        Révélez la <em>beauté</em> de vos cheveux
      </h1>
      <p class="valon-hero__text">
        VALON combine les trésors naturels du Maroc — huile d'argan, figue de barbarie, romarin — avec des formules scientifiquement testées pour des cheveux plus forts, plus brillants et visiblement plus sains.
      </p>
      <p class="valon-hero__darija">غدي تلاحظ تحول رهيب في شعرك — Cheveux forts, brillants, w ma kaytferrochouch.</p>
      <div class="valon-hero__actions">
        <a href="/collections/all" class="valon-btn valon-btn--primary valon-btn--lg">Commander — Paiement à la livraison</a>
        <a href="/pages/notre-histoire" class="valon-btn valon-btn--secondary valon-btn--lg valon-hero__btn-secondary">Notre histoire</a>
      </div>
      <div class="valon-hero__trust">
        <div class="valon-hero__trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          4.9/5 — 2 400+ avis
        </div>
        <div class="valon-hero__trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Paiement à la livraison
        </div>
        <div class="valon-hero__trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          Livraison 48-72h
        </div>
      </div>
    </div>
    <div class="valon-hero__visual">
      <div class="valon-hero__image-wrap">
        {% if section.settings.hero_image %}
          {{ section.settings.hero_image | image_url: width: 800 | image_tag: loading: 'eager', alt: 'VALON Hair Care' }}
        {% else %}
          <div class="valon-hero__image-placeholder">
            Image hero — Produit VALON<br><small>Remplacer dans l'éditeur de thème</small>
          </div>
        {% endif %}
      </div>
      <div class="valon-hero__float-badge">
        <strong>94%</strong>
        des clientes constatent des cheveux plus brillants en 21 jours*
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero VALON",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Image hero"
    }
  ]
}
{% endschema %}
