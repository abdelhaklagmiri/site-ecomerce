<section class="section"><div class="container page-content">
  <h1 class="heading-serif heading-lg">Rechercher</h1>
  <form action="{{ routes.search_url }}" method="get" style="margin:1.5rem 0;">
    <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Huile, Shampooing, Pack..." style="width:100%;padding:1rem;border:1px solid var(--color-gray-light);">
  </form>
  {% if search.performed and search.results_count > 0 %}
    <div class="showcase-grid" style="grid-template-columns:repeat(auto-fill,minmax(250px,1fr));">
      {% for item in search.results %}{% if item.object_type == 'product' %}{% render 'product-card', product: item %}{% endif %}{% endfor %}
    </div>
  {% endif %}
</div></section>
{% schema %}{"name":"Recherche","settings":[],"presets":[{"name":"Recherche"}]}{% endschema %}
