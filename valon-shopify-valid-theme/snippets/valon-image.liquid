{%- comment -%}
  Image with theme asset fallback when image_picker is empty.
  Usage: {% render 'valon-image', image: section.settings.image, fallback: 'images/valon-hero-splash.png', alt: 'VALON', width: 1920, height: 1080, loading: 'eager', class: 'hero__img' %}
{%- endcomment -%}

{%- liquid
  assign img_width = width | default: 1200
  assign img_height = height | default: 1200
  assign img_loading = loading | default: 'lazy'
  assign img_class = class | default: ''
-%}

{%- if image != blank -%}
  <img
    src="{{ image | image_url: width: img_width }}"
    alt="{{ image.alt | default: alt }}"
    width="{{ img_width }}"
    height="{{ img_height }}"
    loading="{{ img_loading }}"
    {% if img_class != blank %}class="{{ img_class }}"{% endif %}
  >
{%- elsif fallback != blank -%}
  <img
    src="{{ fallback | asset_url }}"
    alt="{{ alt }}"
    width="{{ img_width }}"
    height="{{ img_height }}"
    loading="{{ img_loading }}"
    {% if img_class != blank %}class="{{ img_class }}"{% endif %}
  >
{%- endif -%}
